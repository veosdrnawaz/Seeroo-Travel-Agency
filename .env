# ════════════════════════════════════════════════════════
#  Seeroo Travels Attock — Backend Configuration
#  Phase 7: Production Hardening
# ════════════════════════════════════════════════════════

# ── Environment Mode ─────────────────────────────────────
# Options: development | production
# In production mode, missing keys cause immediate startup failure.
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────
# Development default: SQLite (no setup required)
DATABASE_URL=sqlite:///./seeroo_travels.db

# Production: PostgreSQL
# DATABASE_URL=postgresql://seeroo_user:password@localhost:5432/seeroo_travels_db

# ── Server ───────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── CORS (production only, comma-separated origins) ──────
# Leave empty in development (allows all origins)
CORS_ORIGINS=

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=

# ── SMTP Email (Phase 6) ──────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rajakhalilahmad76@gmail.com
SMTP_PASS=ucdn evht hppf vavq

# ── Redis (Phase 7) ──────────────────────────────────────
# Required in production for persistent rate limiting + agent memory.
# Format: redis://[:password@]host[:port][/db-number]
# Example: redis://localhost:6379/0
# Leave empty in development to use SQLite fallback.
REDIS_URL=

# ── Request Limits ────────────────────────────────────────
MAX_REQUEST_SIZE_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=30

# ── Logging ──────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
# LOG_JSON: true (JSON Lines, production) | false (coloured dev output)
LOG_LEVEL=INFO
LOG_JSON=false
